@{
    ViewData["Title"] = "Approve Consultations";
    Layout = "_Layout"; // Explicitly link the main navigation and footer
}

@model IEnumerable<Diet.Models.Appointment>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #2C3E50;">Consultation Management</h2>
        <span class="badge rounded-pill bg-success px-3">Logged in as Admin</span>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Patient Details</th>
                        <th>Date & Time</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@app.FullName</div>
                                <div class="text-muted small">@app.Email</div>
                                @if (!string.IsNullOrEmpty(app.PhoneNumber))
                                {
                                    <div class="text-muted small">@app.PhoneNumber</div>
                                }
                            </td>
                            <td>
                                <div class="fw-bold">@app.StartTime.ToString("MMM dd, yyyy")</div>
                                <div class="text-muted small">@app.StartTime.ToString("hh:mm tt")</div>
                            </td>
                            <td>
                                @if (app.IsConfirmed)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3">Confirmed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3">Pending</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (!app.IsConfirmed)
                                {
                                    <button class="btn btn-success btn-sm rounded-pill px-3 shadow-sm"
                                            onclick="confirmAppointment(@app.Id)">
                                        Confirm
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    async function confirmAppointment(id) {
        if (!confirm("Confirm this booking? This will send the confirmation email.")) return;

        const response = await fetch(`/Admin/ConfirmAppointment/${id}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() }
        });

        const result = await response.json();
        if (result.success) {
            alert(result.message);
            location.reload();
        } else {
            alert("Error: " + result.message);
        }
    }
</script>