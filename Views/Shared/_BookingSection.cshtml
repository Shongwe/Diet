@{
    ViewData["Title"] = "Book a Consultation";
}

<div class="bg-light-subtle min-vh-100 pb-5">
    <div class="container pt-5 pb-4 text-center">
        <span class="badge rounded-pill px-3 py-2 mb-3" style="background-color: rgba(46, 204, 113, 0.1); color: #27ae60; font-weight: 600;">
            <i class="bi bi-calendar-check me-1"></i> Personalized Nutrition Care
        </span>
        <h1 class="display-5 fw-bold mb-3" style="color: #2C3E50;">Schedule Your Consultation</h1>
        <p class="text-muted mx-auto mb-4" style="max-width: 650px; font-size: 1.1rem;">
            Select an available time slot below to start your journey with Jeanett Mampane and our team of registered dietitians.
        </p>
    </div>

    <div class="container mt-4">
        <div class="row justify-content-center align-items-start gx-lg-5 mb-5">
            <div id="calendar-col" class="col-lg-7 transition-all">
                <div class="card shadow-sm p-3 border-0 rounded-4">
                    <div id='calendar'></div>
                </div>
            </div>

            <div id="details-col" class="col-lg-4 d-none">
                <div class="card shadow-lg border-0 rounded-4 overflow-hidden mt-lg-0 mt-4">
                    <div class="p-3 text-white" style="background-color: var(--brand-green, #2ECC71);">
                        <h5 class="mb-0 fw-bold">Confirm Your Booking</h5>
                    </div>
                    <div class="card-body p-4">
                        <p class="text-muted mb-3">You selected: <br><span id="displayTime" class="fw-bold text-dark"></span></p>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Full Name</label>
                            <input type="text" id="patientName" class="form-control rounded-pill" placeholder="e.g. John Doe">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Phone Number</label>
                            <input type="tel" id="patientPhone" class="form-control rounded-pill" placeholder="+27 12 345 6789">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            <input type="email" id="patientEmail" class="form-control rounded-pill" placeholder="name@example.com">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Additional Notes</label>
                            <textarea id="patientNotes" class="form-control rounded-4" rows="2" placeholder="Tell us about your goals..."></textarea>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button id="confirmBooking" class="btn btn-success rounded-pill py-2 fw-bold shadow-sm">Request Appointment</button>
                            <button onclick="cancelBooking()" class="btn btn-link text-muted btn-sm">Change Time</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js'></script>

    <script>
        var selectedStartTime = "";
        var calendarEl = document.getElementById('calendar');

        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'timeGridWeek',
            slotDuration: '00:30:00',
            selectable: true,
            allDaySlot: false,
            weekends: false,
            slotMinTime: '08:00:00',
            slotMaxTime: '17:00:00',
            businessHours: {
                daysOfWeek: [1, 2, 3, 4, 5],
                startTime: '08:00',
                endTime: '17:00',
            },
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'timeGridWeek,dayGridMonth'
            },
            events: '/Booking/GetBookedSlots',
            select: function(info) {
                selectedStartTime = info.startStr;
                let dateObj = new Date(selectedStartTime);

                document.getElementById('displayTime').innerText = dateObj.toLocaleString([], {
                    weekday: 'short', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
                });

                document.getElementById('details-col').classList.remove('d-none');
                document.getElementById('calendar-col').classList.replace('col-lg-12', 'col-lg-7');

                setTimeout(() => { calendar.updateSize(); }, 400);
            }
        });

        calendar.render();

        function cancelBooking() {
            const detailsCol = document.getElementById('details-col');
            const calendarCol = document.getElementById('calendar-col');
            detailsCol.classList.add('d-none');
            calendarCol.classList.replace('col-lg-7', 'col-lg-8');
            setTimeout(() => { calendar.updateSize(); }, 400);
        }

        document.getElementById('confirmBooking').addEventListener('click', function() {
            const name = document.getElementById('patientName').value;
            const email = document.getElementById('patientEmail').value;
            const phone = document.getElementById('patientPhone').value;
            const notes = document.getElementById('patientNotes').value;

            if(!name || !email || !phone) {
                alert("Please fill in required details (Name, Email, and Phone).");
                return;
            }

            const data = {
                FullName: name,
                Email: email,
                PhoneNumber: phone,
                Notes: notes,
                StartTime: selectedStartTime
            };

            // Loading state
            const btn = document.getElementById('confirmBooking');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
            btn.disabled = true;

            fetch('/Booking/CreateAppointment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    // REDIRECT: Redirect to the Success page URL provided by the controller
                    window.location.href = result.redirectUrl;
                } else {
                    btn.innerHTML = 'Request Appointment';
                    btn.disabled = false;
                    alert("Error: " + result.message);
                }
            })
            .catch(error => {
                btn.innerHTML = 'Request Appointment';
                btn.disabled = false;
                console.error('Error:', error);
            });
        });
    </script>

    <style>
        /* Typography & Layout */
        .transition-all {
            transition: all 0.4s ease-in-out;
        }

        #calendar {
            max-width: 100%;
            height: 550px !important;
        }

        .fc .fc-timegrid-slot {
            height: 2.0em !important;
        }

        .fc-timegrid-slot-label-cushion, .fc-daygrid-day-number, .fc-col-header-cell-cushion {
            color: #2ECC71 !important;
            text-decoration: none !important;
            font-weight: 600;
        }

        .fc-button-primary {
            background-color: #2ECC71 !important;
            border: none !important;
        }
    </style>
</div>