@model Diet.Models.LoginViewModel
@{
    ViewData["Title"] = "Admin Login";
    Layout = null; // This removes the main header and footer
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NJ Seroka</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            width: 100%;
            max-width: 400px;
            padding: 2rem;
            border-radius: 20px;
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            background: white;
        }

        .btn-signin {
            background-color: #2ecc71;
            border: none;
            font-weight: 600;
            padding: 12px;
            transition: 0.3s;
        }

            .btn-signin:hover {
                background-color: #27ae60;
                transform: translateY(-2px);
            }

        .logo-img {
            height: 60px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="text-center mb-4">
            <img src="~/images/logo.jpeg" alt="NJ Seroka Logo" class="logo-img">
            <h4 class="fw-bold text-dark">User Portal</h4>
            <p class="text-muted small">Sign in to manage appointments</p>
        </div>

        <form asp-action="Login" asp-controller="Admin" method="post">
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("LoginFailure"))
            {
                <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center mb-4" role="alert" style="border-radius: 12px; font-size: 0.85rem;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>
                        @Html.ValidationMessage("LoginFailure")
                    </div>
                </div>
            }
            <div class="mb-3">
                <label class="form-label text-secondary small fw-bold">Email Address</label>
                <input asp-for="Email" class="form-control form-control-lg border-light bg-light" placeholder="name@gmail.com" style="font-size: 0.9rem;" />
            </div>
            <div class="mb-4">
                <label class="form-label text-secondary small fw-bold">Password</label>
                <input asp-for="Password" type="password" class="form-control form-control-lg border-light bg-light" placeholder="••••••••" />
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-success btn-signin rounded-pill">
                    Sign In
                </button>
            </div>
        </form>

        <div class="text-center mt-4">
            <a href="/" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left"></i> Back to Website</a>
        </div>
    </div>

</body>
</html>